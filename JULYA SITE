<script>
    (function(){
        window.addEventListener('scroll', () => {
            document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 50);
        }, { passive: true });

        const services = [
            { 
                name: "Alongamento de Unhas", 
                price: "Aplicação: R$95,00 | Manutenção: R$75,00 | Unha Quebrada: R$5,00",
                desc: "Ideal para quem deseja unhas instantaneamente longas, resistentes e personalizadas. Permite escolher formato, tamanho e decoração. Durabilidade e manutenção entre 15 e 30 dias."
            },
            { 
                name: "Banho de Gel", 
                price: "Aplicação: R$85,00 | Manutenção: R$75,00 | Unha Quebrada: R$5,00",
                desc: "Ideal para unhas naturais que crescem mas quebram. Oferece proteção, resistência e acabamento sofisticado. Permite encapsulamentos e decorações. Durabilidade entre 15 e 30 dias."
            },
            { 
                name: "Esmaltação em Gel", 
                price: "R$50,00",
                desc: "Maior durabilidade que esmaltes tradicionais. Brilho intenso. Secagem imediata. Durabilidade de 15 a 20 dias."
            },
            { 
                name: "Blindagem", 
                price: "R$50,00",
                desc: "Proteção para unhas naturais. Mantém aspecto saudável. Ideal para quem gosta de unhas curtas. Durabilidade entre 15 e 20 dias. Não inclui esmaltação em gel."
            },
            { 
                name: "Remoção", 
                price: "Consultar",
                desc: "Remoção segura do gel sem danificar as unhas naturais. Ideal para troca de procedimento ou retirada definitiva."
            },
            { 
                name: "Spa dos Pés", 
                price: "R$60,00",
                desc: "Inclui: Higienização • Remoção de calosidades • Lixamento manual e com motor • Esfoliação • Hidratação profunda • Cutilagem • Massagem relaxante. Resultado imediato."
            },
            { 
                name: "Esmaltação em Gel nos Pés", 
                price: "R$40,00",
                desc: "Acabamento impecável. Brilho duradouro. Durabilidade de 20 a 30 dias."
            },
            { 
                name: "Design de Sobrancelhas", 
                price: "R$25,00",
                desc: "Design personalizado conforme o formato do rosto. Mais simetria e harmonia facial. Duração média de 15 a 30 dias."
            },
            { 
                name: "Design com Henna", 
                price: "R$30,00",
                desc: "Definição e preenchimento das sobrancelhas. Acabamento natural e elegante."
            }
        ];

        // APENAS O COMBO PÉS PERFEITOS
        const combos = [
            { name: "Pés Perfeitos", price: 85, items: ["Spa dos Pés", "Esmaltação em Gel nos Pés"], badge: "Mais Pedido", economy: 15 }
        ];

        const marqueeInner = document.getElementById('marqueeInner');
        let mc = '';
        for (let i = 0; i < 4; i++) {
            services.forEach(s => {
                mc += `<span class="marquee-item">${s.name}</span><span class="marquee-sep">✦</span>`;
            });
        }
        marqueeInner.innerHTML = mc;

        const servicesList = document.getElementById('servicesList');
        const serviceSelect = document.getElementById('service');
        servicesList.innerHTML = '';
        serviceSelect.innerHTML = '<option value="">Selecione um serviço</option>';

        services.forEach((s, idx) => {
            const opt = document.createElement('option');
            opt.value = s.name;
            opt.textContent = s.name;
            serviceSelect.appendChild(opt);

            const item = document.createElement('div');
            item.className = 'service-item reveal';
            item.innerHTML = `
                <div class="service-row">
                    <span class="service-num">0${idx+1}</span>
                    <div class="service-info">
                        <div class="service-name">${s.name}</div>
                        <div class="service-price">${s.price}</div>
                    </div>
                    <div class="service-icon">+</div>
                </div>
                <div class="service-desc">${s.desc}</div>`;
            item.addEventListener('click', () => {
                const isOpen = item.classList.contains('open');
                document.querySelectorAll('.service-item.open').forEach(el => el.classList.remove('open'));
                if (!isOpen) item.classList.add('open');
            });
            servicesList.appendChild(item);
        });

        const combosSection = document.getElementById('combosSection');
        if(combosSection) {
            combosSection.innerHTML = `
                <div class="sec-label">Especiais</div>
                <h2 class="sec-title">Nossos<br><em>Combos</em></h2>
                <div class="combo-grid" id="comboGrid"></div>
            `;
            const comboGrid = document.getElementById('comboGrid');
            combos.forEach(c => {
                const card = document.createElement('div');
                card.className = 'combo-card reveal';
                let badgeHtml = c.badge ? `<div class="combo-badge">${c.badge}</div>` : '';
                let saveHtml = c.economy > 0 ? `<span class="combo-save">(Economia R$${c.economy},00)</span>` : '';
                card.innerHTML = `
                    ${badgeHtml}
                    <div class="combo-name">${c.name}</div>
                    <div class="combo-items">${c.items.join(' • ')}</div>
                    <div class="combo-price">R$${c.price},00 ${saveHtml}</div>
                `;
                comboGrid.appendChild(card);
            });
        }

        function isTimeSlotValid(dateStr, timeStr) {
            if (!dateStr || !timeStr) return true;
            const selectedDate = new Date(dateStr);
            const dayOfWeek = selectedDate.getDay();
            if (dayOfWeek === 0) return false;
            const [hour, minute] = timeStr.split(':').map(Number);
            const timeValue = hour + minute/60;
            if (dayOfWeek === 3 || dayOfWeek === 5 || dayOfWeek === 6) {
                return timeValue >= 14.0 && timeValue <= 18.5;
            } else {
                return timeValue >= 9.0 && timeValue <= 18.5;
            }
        }

        const form = document.getElementById('appointmentForm');
        const nameInp = document.getElementById('name');
        const phoneInp = document.getElementById('phone');
        const dateInp = document.getElementById('date');
        const timeInp = document.getElementById('time');
        const obsInp = document.getElementById('obs');

        function clearErrors() {
            document.querySelectorAll('.field.error').forEach(f => {
                f.classList.remove('error');
                const oldMsg = f.querySelector('.error-message');
                if(oldMsg) oldMsg.remove();
            });
            const globalErr = document.querySelector('.global-error');
            if(globalErr) globalErr.remove();
        }

        function showFieldError(fieldElement, message) {
            fieldElement.classList.add('error');
            let errDiv = fieldElement.querySelector('.error-message');
            if(!errDiv) {
                errDiv = document.createElement('div');
                errDiv.className = 'error-message';
                fieldElement.appendChild(errDiv);
            }
            errDiv.innerText = message;
        }

        function showGlobalError(message) {
            let globalErr = document.querySelector('.global-error');
            if(!globalErr) {
                globalErr = document.createElement('div');
                globalErr.className = 'error-message global-error';
                globalErr.style.marginBottom = '16px';
                globalErr.style.textAlign = 'center';
                const formHeader = document.querySelector('#form .form-inner-grid .form-head');
                if(formHeader) formHeader.insertAdjacentElement('afterend', globalErr);
            }
            globalErr.innerText = message;
        }

        function validateForm() {
            let isValid = true;
            clearErrors();

            if(!nameInp.value.trim()) {
                showFieldError(document.querySelector('[data-field="name"]'), 'Nome obrigatório');
                isValid = false;
            }
            if(!phoneInp.value.trim()) {
                showFieldError(document.querySelector('[data-field="phone"]'), 'Telefone obrigatório');
                isValid = false;
            }
            if(!serviceSelect.value) {
                showFieldError(document.querySelector('[data-field="service"]'), 'Selecione um serviço');
                isValid = false;
            }
            if(!dateInp.value) {
                showFieldError(document.querySelector('[data-field="date"]'), 'Selecione a data');
                isValid = false;
            }
            if(!timeInp.value) {
                showFieldError(document.querySelector('[data-field="time"]'), 'Selecione o horário');
                isValid = false;
            }

            if(dateInp.value && timeInp.value && isValid) {
                if(!isTimeSlotValid(dateInp.value, timeInp.value)) {
                    showFieldError(document.querySelector('[data-field="time"]'), 'Horário indisponível. Funcionamento: Segunda a Sábado, 9h-18h30 (Ter/Qui/Sex apenas 14h-18h30).');
                    isValid = false;
                }
            }

            if(!isValid) {
                showGlobalError('Preencha todos os campos obrigatórios e verifique os horários permitidos.');
                return false;
            }
            return true;
        }

        function generateICS(data) {
            const startDate = new Date(`${data.date}T${data.time}:00`);
            const endDate = new Date(startDate.getTime() + 60*60*1000);
            const formatICS = (d) => d.toISOString().replace(/-|:|\.\d+/g, '');
            const dtStart = formatICS(startDate);
            const dtEnd = formatICS(endDate);
            const summary = "Agendamento - Julya Nail Designer";
            const description = `Nome: ${data.name}\nTelefone: ${data.phone}\nServiço: ${data.service}\nObservações: ${data.obs}`;
            return `BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//Julya Nail//Agendamento//PT
BEGIN:VEVENT
UID:${Date.now()}@julyanail.com
DTSTAMP:${dtStart}
DTSTART:${dtStart}
DTEND:${dtEnd}
SUMMARY:${summary}
DESCRIPTION:${description.replace(/\n/g, '\\n')}
END:VEVENT
END:VCALENDAR`;
        }

        let pendingFormData = null;

        function openWhatsAppAndModal(formData) {
            const msg = `Olá! Gostaria de agendar um atendimento premium.\n\n👤 Nome: ${formData.name}\n📞 Telefone: ${formData.phone}\n💅 Serviço: ${formData.service}\n📅 Data: ${formData.date}\n⏰ Horário: ${formData.time}\n📝 Observações: ${formData.obs || '—'}\n\nAguardo confirmação.`;
            const waUrl = `https://wa.me/558188073807?text=${encodeURIComponent(msg)}`;
            window.open(waUrl, '_blank');
            pendingFormData = formData;
            const modal = document.getElementById('modalConfirm');
            modal.classList.add('active');
        }

        form.addEventListener('submit', (e) => {
            e.preventDefault();
            if(!validateForm()) return;
            const formData = {
                name: nameInp.value.trim(),
                phone: phoneInp.value.trim(),
                service: serviceSelect.value,
                date: dateInp.value,
                time: timeInp.value,
                obs: obsInp.value.trim() || ''
            };
            openWhatsAppAndModal(formData);
        });

        const modal = document.getElementById('modalConfirm');
        const addCalBtn = document.getElementById('modalAddCalendar');
        const closeModalBtn = document.getElementById('modalCloseBtn');
        function closeModal() { modal.classList.remove('active'); pendingFormData = null; }
        closeModalBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => { if(e.target === modal) closeModal(); });
        addCalBtn.addEventListener('click', () => {
            if(pendingFormData) {
                const icsContent = generateICS(pendingFormData);
                const blob = new Blob([icsContent], {type: 'text/calendar'});
                const link = document.createElement('a');
                const url = URL.createObjectURL(blob);
                link.href = url;
                link.download = `Agendamento_Julya_${pendingFormData.date}.ics`;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                URL.revokeObjectURL(url);
                closeModal();
            } else { closeModal(); }
        });

        const io = new IntersectionObserver(entries => {
            entries.forEach((e, idx) => {
                if (e.isIntersecting) {
                    setTimeout(() => e.target.classList.add('visible'), idx * 60);
                    io.unobserve(e.target);
                }
            });
        }, { threshold: 0.08 });
        document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    })();
</script>
